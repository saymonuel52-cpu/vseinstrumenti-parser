{
  "ParserSettings": {
    "BaseUrls": {
      "Vseinstrumenti": "https://www.vseinstrumenti.ru",
      "Volt220": "https://www.220-volt.ru"
    },
    "RequestSettings": {
      "TimeoutSeconds": 30,
      "MaxRetries": 3,
      "RetryDelayMs": 1000,
      "DelayBetweenRequestsMs": 2000,
      "UserAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
    },
    "ParsingLimits": {
      "MaxPagesPerCategory": 10,
      "MaxProductsPerPage": 50,
      "MaxConcurrentRequests": 3,
      "EnableCaching": true,
      "CacheDurationMinutes": 60
    },
    "ExportSettings": {
      "DefaultFormat": "CSV",
      "OutputDirectory": "./exports",
      "IncludeTimestamp": true,
      "CompressOutput": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    },
    "FileLogging": {
      "Enabled": true,
      "Path": "./logs/parser_{0:yyyyMMdd}.log",
      "MaxFileSizeMB": 10,
      "RetainedFileCount": 7
    },
    "ConsoleLogging": {
      "Enabled": true,
      "IncludeTimestamp": true
    }
  },
  "DatabaseSettings": {
    "ConnectionString": "Data Source=./data/parser.db",
    "Provider": "SQLite",
    "AutoCreateTables": true
  },
  "NotificationSettings": {
    "Telegram": {
      "Enabled": false,
      "BotToken": "",
      "ChatId": ""
    },
    "Email": {
      "Enabled": false,
      "SmtpServer": "",
      "Port": 587,
      "Username": "",
      "Password": ""
    }
  }
}