{
  "ParserSettings": {
    "BaseUrls": {
      "Vseinstrumenti": "https://www.vseinstrumenti.ru",
      "Volt220": "https://www.220-volt.ru"
    },
    "RequestSettings": {
      "TimeoutSeconds": 60,
      "MaxRetries": 5,
      "RetryDelayMs": 2000,
      "DelayBetweenRequestsMs": 3000,
      "UserAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
      "UseProxy": false,
      "ProxyUrl": "",
      "RateLimitRequestsPerMinute": 30,
      "EnableCircuitBreaker": true,
      "CircuitBreakerFailureThreshold": 5,
      "CircuitBreakerSamplingDurationSeconds": 30,
      "CircuitBreakerMinimumThroughput": 10,
      "CircuitBreakerDurationOfBreakSeconds": 60
    },
    "ParsingLimits": {
      "MaxPagesPerCategory": 5,
      "MaxProductsPerPage": 100,
      "MaxConcurrentRequests": 5,
      "EnableCaching": true,
      "CacheDurationMinutes": 120,
      "MaxTotalProducts": 10000,
      "EnableIncrementalParsing": true
    },
    "ExportSettings": {
      "DefaultFormat": "JSON",
      "OutputDirectory": "/app/exports",
      "IncludeTimestamp": true,
      "CompressOutput": true,
      "CompressionLevel": "Optimal",
      "EncryptOutput": false,
      "EncryptionKey": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning",
      "VseinstrumentiParser": "Information"
    },
    "FileLogging": {
      "Enabled": true,
      "Path": "/app/logs/parser_{0:yyyyMMdd}.log",
      "MaxFileSizeMB": 100,
      "RetainedFileCount": 30,
      "RollingInterval": "Day",
      "RetainedFileTimeLimit": "30.00:00:00"
    },
    "ConsoleLogging": {
      "Enabled": false,
      "IncludeTimestamp": true
    },
    "SeqLogging": {
      "Enabled": true,
      "ServerUrl": "http://seq:5341",
      "ApiKey": "",
      "BufferSize": 1000,
      "BatchSize": 100
    },
    "OpenTelemetryLogging": {
      "Enabled": true,
      "Endpoint": "http://otel-collector:4317"
    }
  },
  "Redis": {
    "ConnectionString": "redis:6379,password=,abortConnect=false,connectTimeout=5000,syncTimeout=5000",
    "InstanceName": "VseinstrumentiParser",
    "DefaultSlidingExpirationSeconds": 3600,
    "DefaultAbsoluteExpirationSeconds": 86400
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "vseinstrumenti-parser",
    "ServiceVersion": "1.0.0",
    "Endpoint": "http://otel-collector:4317",
    "Protocol": "grpc",
    "ExportIntervalMilliseconds": 10000,
    "ExportTimeoutMilliseconds": 30000,
    "MaxExportBatchSize": 512,
    "MaxQueueSize": 2048,
    "Metrics": {
      "Enabled": true,
      "MeterName": "VseinstrumentiParser.Metrics"
    },
    "Tracing": {
      "Enabled": true,
      "Sampler": "ParentBased_AlwaysOn"
    },
    "Logs": {
      "Enabled": true,
      "IncludeFormattedMessage": true
    }
  },
  "HealthChecks": {
    "Enabled": true,
    "Endpoint": "/health",
    "TimeoutSeconds": 10,
    "EvaluationTimeSeconds": 30,
    "MinimumSecondsBetweenFailureNotifications": 60,
    "StorageConnectionString": "",
    "StorageContainerName": "healthchecks"
  },
  "Monitoring": {
    "Prometheus": {
      "Enabled": true,
      "Endpoint": "/metrics",
      "ScrapeIntervalSeconds": 15
    },
    "Grafana": {
      "Enabled": true,
      "DashboardUrl": "http://grafana:3000"
    },
    "Alerting": {
      "Enabled": true,
      "SlackWebhookUrl": "",
      "TelegramBotToken": "",
      "TelegramChatId": "",
      "EmailSmtpServer": "",
      "EmailFrom": "",
      "EmailTo": ""
    }
  },
  "Security": {
    "EnableHttpsRedirection": true,
    "HttpsPort": 443,
    "EnableHsts": true,
    "HstsMaxAgeDays": 365,
    "EnableCors": false,
    "CorsOrigins": [],
    "EnableRateLimiting": true,
    "RateLimitPermitLimit": 100,
    "RateLimitWindowSeconds": 60,
    "EnableAuthentication": false,
    "AuthenticationScheme": "Bearer",
    "ApiKey": ""
  },
  "BackgroundTasks": {
    "CacheCleanupIntervalMinutes": 60,
    "ExportCleanupIntervalHours": 24,
    "HealthCheckIntervalSeconds": 30,
    "MetricsCollectionIntervalSeconds": 10,
    "MaxConcurrentBackgroundTasks": 3
  },
  "Performance": {
    "MaxDegreeOfParallelism": 10,
    "MaxMemoryUsageMB": 1024,
    "GarbageCollectionMode": "Balanced",
    "ThreadPoolMinThreads": 10,
    "ThreadPoolMaxThreads": 100
  },
  "ExternalServices": {
    "Vseinstrumenti": {
      "ApiEndpoint": "",
      "ApiKey": "",
      "UseOfficialApi": false
    },
    "Volt220": {
      "ApiEndpoint": "",
      "ApiKey": "",
      "UseOfficialApi": false
    }
  }
}