@page "/compare"
@inject NavigationManager Navigation
@inject VseinstrumentiParserService ParserService
@inject HttpClient Http
@inject IDistributedCache Cache

<h1 class="mb-4">
    <i class="bi bi-table"></i> Сравнение цен
</h1>

<!-- Search and Filters -->
<div class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Поиск товара</label>
                <input type="text" class="form-control" @bind="searchQuery" placeholder="Название, бренд, категория..." @onkeypress="HandleKeyPress">
            </div>
            <div class="col-md-2">
                <label class="form-label">Цена от</label>
                <input type="number" class="form-control" @bind="minPrice" placeholder="0">
            </div>
            <div class="col-md-2">
                <label class="form-label">Цена до</label>
                <input type="number" class="form-control" @bind="maxPrice" placeholder="Любая">
            </div>
            <div class="col-md-2">
                <label class="form-label">Бренд</label>
                <select class="form-select" @bind="selectedBrand">
                    <option value="">Все бренды</option>
                    @foreach (var brand in brands)
                    {
                        <option value="@brand">@brand</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary w-100" @onclick="SearchProducts">
                    <i class="bi bi-search"></i> Поиск
                </button>
            </div>
        </div>

        <!-- Additional Filters -->
        <div class="row g-3 mt-2">
            <div class="col-md-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="inStockOnly" @bind="inStockOnly">
                    <label class="form-check-label" for="inStockOnly">Только в наличии</label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="sortByPrice" @bind="sortByPriceAsc">
                    <label class="form-check-label" for="sortByPrice">Сортировка: по цене (возр.)</label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="sortByDiff" @bind="sortByDifference">
                    <label class="form-check-label" for="sortByDiff">Сортировка: по разнице</label>
                </div>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-outline-primary" @onclick="RefreshData" disabled="@isRefreshing">
                    @if (isRefreshing)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="bi bi-arrow-clockwise"></i> Обновить данные
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Cache Status -->
@if (cacheHit)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <i class="bi bi-info-circle"></i>
        Данные из кэша. Последнее обновление: @lastCacheUpdate.ToString("dd.MM HH:mm:ss")
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Loading State -->
@if (loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Загрузка...</span>
        </div>
        <p class="mt-3 text-muted">Поиск товаров...</p>
    </div>
}
else if (comparisonResults.Count == 0 && !loading)
{
    <div class="alert alert-warning text-center py-5">
        <i class="bi bi-inbox fs-1"></i>
        <p class="mt-3">Товары не найдены. Попробуйте изменить параметры поиска.</p>
    </div>
}
else
{
    <!-- Results Summary -->
    <div class="alert alert-success mb-4">
        <i class="bi bi-check-circle"></i>
        Найдено товаров: <strong>@comparisonResults.Count</strong> |
        Средняя разница цен: <strong>@averageDifference.ToString("F2")%</strong>
    </div>

    <!-- Results Table -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-list-ul"></i> Результаты сравнения</h5>
            <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-primary" @onclick="ExportCsv">
                    <i class="bi bi-filetype-csv"></i> CSV
                </button>
                <button class="btn btn-outline-secondary" @onclick="ExportJson">
                    <i class="bi bi-filetype-json"></i> JSON
                </button>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 30%;">Товар</th>
                        <th class="text-center">vseinstrumenti.ru</th>
                        <th class="text-center">220-volt.ru</th>
                        <th class="text-center">Разница</th>
                        <th class="text-center">Лучшее предложение</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var result in comparisonResults)
                    {
                        <tr>
                            <td>
                                <strong>@result.ProductName</strong>
                                <br />
                                <small class="text-muted">@result.Brand | @result.Article</small>
                            </td>
                            <td class="text-center">
                                @if (result.VseinstrumentiProduct != null)
                                {
                                    <div>
                                        <strong class="text-primary">@result.VseinstrumentiProduct.Price?.ToString("N0") ₽</strong>
                                        <br />
                                        <small class="text-@(result.VseinstrumentiProduct.Availability == VseinstrumentiParser.Models.AvailabilityStatus.InStock ? "success" : "danger")">
                                            @GetAvailabilityText(result.VseinstrumentiProduct.Availability)
                                        </small>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (result.VoltProduct != null)
                                {
                                    <div>
                                        <strong class="text-info">@result.VoltProduct.Price?.ToString("N0") ₽</strong>
                                        <br />
                                        <small class="text-@(result.VoltProduct.Availability == VseinstrumentiParser.Models.AvailabilityStatus.InStock ? "success" : "danger")">
                                            @GetAvailabilityText(result.VoltProduct.Availability)
                                        </small>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (result.PriceDifference != null)
                                {
                                    <span class="badge bg-@(result.PriceDifference > 0 ? "success" : "warning")">
                                        @result.PriceDifference.Value.ToString("F1")%
                                    </span>
                                    <br />
                                    <small class="text-muted">@result.AbsoluteDifference?.ToString("N0") ₽</small>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (result.BestSource != null)
                                {
                                    <div>
                                        <span class="badge bg-success">
                                            @(result.BestSource == "vseinstrumenti" ? "vseinstrumenti.ru" : "220-volt.ru")
                                        </span>
                                        <br />
                                        <strong>@result.BestPrice?.ToString("N0") ₽</strong>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    @if (result.VseinstrumentiProduct?.Url != null)
                                    {
                                        <a href="@result.VseinstrumentiProduct.Url" target="_blank" class="btn btn-outline-primary" title="Открыть на vseinstrumenti.ru">
                                            <i class="bi bi-box-arrow-up-right"></i>
                                        </a>
                                    }
                                    @if (result.VoltProduct?.Url != null)
                                    {
                                        <a href="@result.VoltProduct.Url" target="_blank" class="btn btn-outline-info" title="Открыть на 220-volt.ru">
                                            <i class="bi bi-box-arrow-up-right"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination (if needed) -->
    @if (comparisonResults.Count >= pageSize)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" @onclick="PreviousPage">Предыдущая</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" @onclick="() => GoToPage(i)">@i</a>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" @onclick="NextPage">Следующая</a>
                </li>
            </ul>
        </nav>
    }
}

@code {
    private string searchQuery = string.Empty;
    private decimal? minPrice;
    private decimal? maxPrice;
    private string selectedBrand = string.Empty;
    private bool inStockOnly = false;
    private bool sortByPriceAsc = true;
    private bool sortByDifference = false;
    
    private bool loading = false;
    private bool isRefreshing = false;
    private bool cacheHit = false;
    private DateTime lastCacheUpdate;
    
    private List<string> brands = new();
    private List<ComparisonResult> comparisonResults = new();
    
    private int currentPage = 1;
    private int pageSize = 20;
    private int totalPages = 1;
    
    private decimal? averageDifference;

    protected override async Task OnInitializedAsync()
    {
        await LoadBrandsAsync();
        await SearchProducts();
    }

    private async Task LoadBrandsAsync()
    {
        // Load brands from cache or parse
        var brandsCacheKey = "brands_list";
        var cachedBrands = await Cache.GetStringAsync(brandsCacheKey);
        
        if (cachedBrands != null)
        {
            brands = System.Text.Json.JsonSerializer.Deserialize<List<string>>(cachedBrands) ?? new();
        }
        else
        {
            // Parse some products to get brands
            var categories = await ParserService.GetCategoriesAsync();
            if (categories.Count > 0)
            {
                var products = await ParserService.GetProductsFromCategoryAsync(categories[0].Url, maxPages: 1);
                brands = products.Select(p => p.Brand).Where(b => !string.IsNullOrEmpty(b)).Distinct().Take(50).ToList();
                
                await Cache.SetStringAsync(brandsCacheKey, System.Text.Json.JsonSerializer.Serialize(brands), 
                    new DistributedCacheEntryOptions { AbsoluteExpirationRelativeToNow = TimeSpan.FromHours(6) });
            }
        }
    }

    private async Task SearchProducts()
    {
        loading = true;
        currentPage = 1;
        StateHasChanged();

        try
        {
            // Check cache
            var cacheKey = $"compare_{searchQuery}_{minPrice}_{maxPrice}_{selectedBrand}_{inStockOnly}";
            var cachedResult = await Cache.GetStringAsync(cacheKey);
            
            if (cachedResult != null)
            {
                var cacheEntry = System.Text.Json.JsonSerializer.Deserialize<CacheEntry>(cachedResult);
                if (cacheEntry != null && DateTime.Now - cacheEntry.Timestamp < TimeSpan.FromMinutes(15))
                {
                    comparisonResults = cacheEntry.Results;
                    cacheHit = true;
                    lastCacheUpdate = cacheEntry.Timestamp;
                    loading = false;
                    StateHasChanged();
                    return;
                }
            }

            cacheHit = false;
            
            // Perform search
            await PerformSearchAsync();
            
            // Cache results
            await Cache.SetStringAsync(cacheKey, System.Text.Json.JsonSerializer.Serialize(new CacheEntry
            {
                Timestamp = DateTime.Now,
                Results = comparisonResults
            }), new DistributedCacheEntryOptions { AbsoluteExpirationRelativeToNow = TimeSpan.FromMinutes(15) });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Search error: {ex.Message}");
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private async Task PerformSearchAsync()
    {
        var allProducts = new List<Product>();
        
        // Parse from both sources
        var vsiProducts = await ParserService.GetProductsFromCategoryAsync(null, maxPages: 5);
        var voltParser = new VoltProductParser(new HttpClientService());
        
        // For demo, we'll compare based on name matching
        // In production, implement proper product matching by SKU/Article
        
        comparisonResults = new List<ComparisonResult>();
        
        foreach (var vsiProduct in vsiProducts.Take(50))
        {
            // Apply filters
            if (!string.IsNullOrEmpty(searchQuery) && 
                !vsiProduct.Name.ToLower().Contains(searchQuery.ToLower()) &&
                !vsiProduct.Brand.ToLower().Contains(searchQuery.ToLower()))
            {
                continue;
            }

            if (minPrice.HasValue && (vsiProduct.Price < minPrice || vsiProduct.Price > maxPrice.GetValueOrDefault(decimal.MaxValue)))
            {
                continue;
            }

            if (!string.IsNullOrEmpty(selectedBrand) && vsiProduct.Brand != selectedBrand)
            {
                continue;
            }

            if (inStockOnly && vsiProduct.Availability != VseinstrumentiParser.Models.AvailabilityStatus.InStock)
            {
                continue;
            }

            // Try to find matching product on volt.ru
            // This is simplified - in production, use SKU matching
            var voltProduct = await FindMatchingVoltProductAsync(vsiProduct, voltParser);

            if (voltProduct != null)
            {
                var difference = CalculatePriceDifference(vsiProduct.Price, voltProduct.Price);
                
                comparisonResults.Add(new ComparisonResult
                {
                    ProductName = vsiProduct.Name,
                    Brand = vsiProduct.Brand,
                    Article = vsiProduct.Article,
                    VseinstrumentiProduct = vsiProduct,
                    VoltProduct = voltProduct,
                    PriceDifference = difference,
                    AbsoluteDifference = Math.Abs((vsiProduct.Price ?? 0) - (voltProduct.Price ?? 0)),
                    BestSource = (vsiProduct.Price ?? 0) < (voltProduct.Price ?? 0) ? "vseinstrumenti" : "volt",
                    BestPrice = Math.Min(vsiProduct.Price ?? 0, voltProduct.Price ?? 0)
                });
            }
        }

        // Sort results
        if (sortByPriceAsc)
        {
            comparisonResults = comparisonResults.OrderBy(x => x.BestPrice).ToList();
        }
        else if (sortByDifference)
        {
            comparisonResults = comparisonResults.OrderByDescending(x => x.PriceDifference).ToList();
        }

        // Calculate average difference
        var differences = comparisonResults.Where(x => x.PriceDifference.HasValue).Select(x => x.PriceDifference.Value).ToList();
        averageDifference = differences.Any() ? differences.Average() : 0;

        totalPages = (int)Math.Ceiling((double)comparisonResults.Count / pageSize);
    }

    private async Task<Product?> FindMatchingVoltProductAsync(Product vsiProduct, VoltProductParser voltParser)
    {
        // Simplified matching - in production, implement better matching logic
        // Try to find by article/SKU
        if (!string.IsNullOrEmpty(vsiProduct.Article))
        {
            var categories = await new VoltCategoryParser(new HttpClientService()).GetCategoriesAsync();
            foreach (var cat in categories.Take(3))
            {
                var productUrls = await new VoltCategoryParser(new HttpClientService()).GetProductUrlsFromCategoryAsync(cat.Url, maxPages: 2);
                foreach (var url in productUrls.Take(10))
                {
                    try
                    {
                        var voltProduct = await voltParser.ParseProductAsync(url);
                        if (voltProduct.Article == vsiProduct.Article || 
                            voltProduct.Name.Contains(vsiProduct.Brand))
                        {
                            return voltProduct;
                        }
                    }
                    catch { /* Continue on error */ }
                }
            }
        }

        return null;
    }

    private decimal? CalculatePriceDifference(decimal? price1, decimal? price2)
    {
        if (!price1.HasValue || !price2.HasValue) return null;
        
        var min = Math.Min(price1.Value, price2.Value);
        var max = Math.Max(price1.Value, price2.Value);
        
        return ((max - min) / min) * 100;
    }

    private string GetAvailabilityText(VseinstrumentiParser.Models.AvailabilityStatus status)
    {
        return status switch
        {
            VseinstrumentiParser.Models.AvailabilityStatus.InStock => "В наличии",
            VseinstrumentiParser.Models.AvailabilityStatus.OutOfStock => "Нет в наличии",
            VseinstrumentiParser.Models.AvailabilityStatus.Limited => "Ограниченно",
            VseinstrumentiParser.Models.AvailabilityStatus.PreOrder => "Под заказ",
            _ => "Неизвестно"
        };
    }

    private async Task RefreshData()
    {
        isRefreshing = true;
        await Cache.RemoveAsync($"compare_{searchQuery}");
        await SearchProducts();
        isRefreshing = false;
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            SearchProducts();
        }
    }

    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            StateHasChanged();
        }
    }

    private void NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            StateHasChanged();
        }
    }

    private void GoToPage(int page)
    {
        currentPage = page;
        StateHasChanged();
    }

    private void ExportCsv()
    {
        // Implement CSV export
    }

    private void ExportJson()
    {
        // Implement JSON export
    }

    public class ComparisonResult
    {
        public string ProductName { get; set; } = string.Empty;
        public string Brand { get; set; } = string.Empty;
        public string Article { get; set; } = string.Empty;
        public Product? VseinstrumentiProduct { get; set; }
        public Product? VoltProduct { get; set; }
        public decimal? PriceDifference { get; set; }
        public decimal? AbsoluteDifference { get; set; }
        public string? BestSource { get; set; }
        public decimal? BestPrice { get; set; }
    }

    public class CacheEntry
    {
        public DateTime Timestamp { get; set; }
        public List<ComparisonResult> Results { get; set; } = new();
    }
}
